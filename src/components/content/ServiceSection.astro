---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<div class="mx-auto max-w-6xl px-4 sm:px-6">
  <div class="bg-slate-50 rounded-2xl px-8 sm:px-14 py-10 sm:py-14">
    <h3>{title}</h3>
    <div set:html={description} />
  </div>
</div>
