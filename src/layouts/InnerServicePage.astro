---
/* =======================================================
 * InnerServicePage.astro
 * Layout for inner service sub-pages (e.g. Booklets & Manuals).
 * Mirrors ServicePage.astro — tabs replace the ChecklistGrid.
 * ======================================================= */

import Layout from "../layouts/Layout.astro";
import SmallHero from "../components/hero/HeroSmall.astro";
import CentreText from "../components/content/CentreText.astro";
import Feature from "../components/content/Feature.astro";
import CTA from "../components/content/CTA.astro";

interface Props {
  content: any;
  imageMap: Record<string, ImageMetadata>;
  checklistBg?: string;
}

const { content, imageMap, checklistBg = "bg-slate-50" } = Astro.props;

const featureNav = content.featureNav ?? [];
const features = content.features ?? [];

// Load small tab icons
const iconModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/icons/small/*.png",
  { eager: true }
);
const iconMap: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(iconModules)) {
  const filename = path.split("/").pop()!;
  iconMap[filename] = mod.default;
}
---

<Layout title={content.site.title} description={content.site.description}>

  <!-- HERO -->
  <SmallHero
    title={content.hero.title}
    imageSrc={imageMap[content.hero.image]}
    imageAlt={content.hero.imageAlt}
    bgColor={content.hero.bgColor}
  />

  <!-- CENTRE TEXT -->
  {content.centreText && (
    <section class={`sm:pt-12 relative ${checklistBg}`}>
      <CentreText
        title={content.centreText.title}
        description={content.centreText.description}
        imageSrc={imageMap[content.centreText.icon].src}
        imageAlt="ION Group Logo"
      />
    </section>
  )}

  <!-- TAB NAV (replaces ChecklistGrid) -->
  {featureNav.length > 0 && (
    <section class={checklistBg}>
      <div class="tab-nav-section">
        <div class="tab-nav-card">
          <!-- Decorative circle (matches ChecklistGrid) -->
          <svg
            class="tab-nav-decoration"
            viewBox="0 0 100 100"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <circle cx="100" cy="100" r="80" fill="currentColor" />
            <path d="M100 60 Q80 80 60 100 L100 100 Z" fill="white" fill-opacity="0.3" />
          </svg>

          <div class="tab-nav-pills">
            {featureNav.map((tab: any, i: number) => (
              <button
                class={`tab-pill${i === 0 ? " active" : ""}`}
                data-target={tab.anchor}
                type="button"
              >
                {iconMap[tab.icon] && (
                  <img
                    src={iconMap[tab.icon].src}
                    alt=""
                    class="tab-icon"
                    width="28"
                    height="28"
                  />
                )}
                {tab.label}
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- FEATURE SECTIONS -->
  <section class="pt-6 sm:py-32 sm:-mt-24 bg-white">
    {features.map((feature: any, i: number) => (
      <div data-panel={feature.id} hidden={featureNav.length > 0 && i !== 0}>
        <Feature
          title={feature.title}
          description={feature.description}
          imageSrc={imageMap[feature.image]}
          imageAlt={feature.imageAlt}
          imagePosition={feature.imagePosition}
          buttonLink={feature.buttonLink}
          buttonText={feature.buttonText}
          buttonTarget={feature.buttonTarget}
        />
      </div>
    ))}
  </section>

  <!-- CTA -->
  {content.cta && (
    <CTA
      heading={content.cta.heading}
      button={content.cta.button}
      link={content.cta.link}
    />
  )}

</Layout>

<script>
  function initTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>(".tab-pill");
    if (!tabs.length) return;

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        tabs.forEach((t) => t.classList.remove("active"));
        tab.classList.add("active");
        const targetId = tab.dataset.target;
        document.querySelectorAll<HTMLElement>("[data-panel]").forEach((p) => {
          p.hidden = true;
        });
        const panel = document.querySelector<HTMLElement>(
          `[data-panel="${targetId}"]`
        );
        if (panel) panel.hidden = false;
      });
    });
  }

  document.addEventListener("astro:page-load", initTabs);
</script>
